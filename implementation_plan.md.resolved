-- [表 8] 店内服务项目定义表 (对齐 ServiceInfo)
CREATE TABLE services (
    service_id INT AUTO_INCREMENT PRIMARY KEY,
    name VARCHAR(50) NOT NULL,
    category ENUM('美容洗护', '医疗保健', '寄养服务', '培训及其他') NOT NULL,
    price DECIMAL(7,2) UNSIGNED NOT NULL,
    duration_min INT UNSIGNED DEFAULT 30,
    commission_type ENUM('比例', '固定金额') DEFAULT '比例',
    commission_value DECIMAL(7,2) UNSIGNED DEFAULT 10.00,
    description TEXT,
    icon_path VARCHAR(255),
    status TINYINT DEFAULT 1,
    is_deleted TINYINT(1) DEFAULT 0
) COMMENT='店内服务项目字典';

-- [表 10] 预约单表 (对齐 AppointmentInfo)
CREATE TABLE appointments (
    appt_id INT AUTO_INCREMENT PRIMARY KEY,
    group_id VARCHAR(32) COMMENT '订单组ID(如接送单和洗护单属于同组)',
    member_id INT NOT NULL,
    pet_id INT NOT NULL,
    service_id INT NOT NULL,
    staff_id INT COMMENT '执行员工',
    station_id INT COMMENT '工位号',
    appt_time DATETIME NOT NULL COMMENT '预约到店时间',
    appt_type VARCHAR(20) DEFAULT '服务' COMMENT 'Transport/Grooming/Boarding',
    status ENUM('待处理', '进行中', '已完成', '已取消') DEFAULT '待处理',
    notes VARCHAR(255) COMMENT '客户备注',
    address VARCHAR(255) COMMENT '接送地址',
    amount DECIMAL(8,2) COMMENT '预约金额估算',
    
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    is_deleted TINYINT(1) DEFAULT 0,
    FOREIGN KEY (member_id) REFERENCES members(member_id),
    FOREIGN KEY (pet_id) REFERENCES pets(pet_id),
    INDEX idx_time_staff (appt_time, staff_id)
) COMMENT='预约管理主表';

-- [新增表 10.1] 物流接送任务表 (对齐 LogisticsTask)
CREATE TABLE logistics_tasks (
    task_id VARCHAR(32) PRIMARY KEY,
    pet_id INT NOT NULL,
    appt_id INT COMMENT '关联的预约单/寄养单',
    task_type ENUM('接宠', '送宠') NOT NULL,
    status ENUM('待处理', '进行中', '已送达', '已完成', '已取消') DEFAULT '待处理',
    driver_id INT COMMENT '关联派送司机(员工ID)',
    address VARCHAR(255) NOT NULL COMMENT '目的地',
    schedule_time DATETIME NOT NULL COMMENT '要求到达时间',
    amount DECIMAL(6,2) DEFAULT 0.00 COMMENT '接送费',
    
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    is_deleted TINYINT(1) DEFAULT 0,
    FOREIGN KEY (pet_id) REFERENCES pets(pet_id)
) COMMENT='车辆接送物流调度表';

