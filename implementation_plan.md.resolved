# 宠物店信息管理系统（Pet Management System）实现计划

本方案旨在设计一个基于 Qt (Client) 和 Linux C++ (Server) 的高性能宠物店管理系统。系统将通过 MySQL 进行持久化存储，并采用 TCP 协议进行高效的数据交互。

## 1. 核心架构设计

### 1.1 系统拓扑 (C/S 架构)
- **客户端 (Qt 6.x)**: 
  - 采用 **Model/View** 架构解耦 UI 与数据。
  - **网络层**: 基于 `QTcpSocket` 封装异步请求管理器，支持二进制流/JSON 数据交换。
  - **UI 特色**: 房态图组件（自定义 QGraphicsView）、收银扫码支持。
- **服务端 (Linux / C++)**:
  - **核心协议**: 自定义 TCP 协议（4字节消息长度头 + 消息体）。
  - **并发处理**: 采用 **Reactor 模式** (Epoll + 线程池) 处理海量连接。
  - **数据层**: 使用 **MySQL 连接池** 提升 SQL 执行效率，减少频繁握手开销。

---

## 2. 数据库逻辑建模 (MySQL)


-- ==========================================
-- 1. 员工与系统配置
-- ==========================================

-- [表 1] 员工信息表 (对齐 EmployeeInfo)
CREATE TABLE sys_employees (
    emp_id INT AUTO_INCREMENT PRIMARY KEY,
    username VARCHAR(32) NOT NULL UNIQUE COMMENT '登录账号',
    password VARCHAR(255) NOT NULL COMMENT '密码哈希',
    real_name VARCHAR(20) NOT NULL COMMENT '真实姓名',
    role ENUM('店长', '收银', '美容师', '司机') NOT NULL DEFAULT '美容师',
    department VARCHAR(50) COMMENT '所属部门',
    gender ENUM('男', '女', '未知') DEFAULT '未知',
    age TINYINT UNSIGNED COMMENT '年龄',
    phone CHAR(11) UNIQUE COMMENT '手机号',
    email VARCHAR(50) COMMENT '邮箱',
    id_card CHAR(18) COMMENT '身份证号',
    base_salary DECIMAL(8,2) UNSIGNED DEFAULT 0 COMMENT '基础底薪',
    join_date DATE COMMENT '入职日期',
    emergency_contact VARCHAR(20) COMMENT '紧急联系人',
    emergency_phone CHAR(11) COMMENT '紧急联系电话',
    address VARCHAR(255) COMMENT '住址',
    education VARCHAR(20) COMMENT '学历',
    status ENUM('在职', '请假', '离职') DEFAULT '在职',
    img_url VARCHAR(255) COMMENT '头像路径',
    
    -- 审计字段
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    is_deleted TINYINT(1) DEFAULT 0 COMMENT '0:有效 1:逻辑删除',
    INDEX idx_real_name (real_name),
    INDEX idx_phone (phone)
) COMMENT='员工全维度档案表';

-- [新增表 1.1] 系统操作日志表 (对齐 SysOperationLog)
CREATE TABLE sys_operation_logs (
    log_id BIGINT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    operator_name VARCHAR(20) NOT NULL COMMENT '操作人姓名',
    module VARCHAR(50) NOT NULL COMMENT '操作模块',
    action VARCHAR(50) NOT NULL COMMENT '动作(如:扣减库存)',
    details TEXT COMMENT '详情/变更差异',
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    INDEX idx_time_module (created_at, module)
) COMMENT='系统操作审计日志';

-- [新增表 1.2] 员工薪资发放记录 (对齐 SalaryInfo)
CREATE TABLE salary_records (
    salary_id INT AUTO_INCREMENT PRIMARY KEY,
    emp_id INT NOT NULL,
    salary_month CHAR(7) NOT NULL COMMENT '薪资月份 YYYY-MM',
    base_salary DECIMAL(8,2) NOT NULL DEFAULT 0.00,
    commission DECIMAL(8,2) NOT NULL DEFAULT 0.00 COMMENT '提成总额',
    bonus DECIMAL(8,2) NOT NULL DEFAULT 0.00 COMMENT '奖金',
    deduction DECIMAL(8,2) NOT NULL DEFAULT 0.00 COMMENT '扣款',
    net_pay DECIMAL(8,2) NOT NULL DEFAULT 0.00 COMMENT '实发金额',
    status ENUM('待审核', '已发放') DEFAULT '待审核',
    pay_time DATETIME COMMENT '发放时间',
    remark VARCHAR(255),
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (emp_id) REFERENCES sys_employees(emp_id),
    UNIQUE KEY idx_emp_month (emp_id, salary_month)
) COMMENT='月度薪资核算表';

-- [表 2] 排班与考勤表
CREATE TABLE sys_schedules (
    schedule_id INT AUTO_INCREMENT PRIMARY KEY,
    emp_id INT NOT NULL,
    work_date DATE NOT NULL,
    shift_type ENUM('休息', '早班', '晚班', '自定义') NOT NULL,
    plan_start TIME,
    plan_end TIME,
    clock_in DATETIME,
    clock_out DATETIME,
    note VARCHAR(100),
    is_deleted TINYINT(1) DEFAULT 0,
    FOREIGN KEY (emp_id) REFERENCES sys_employees(emp_id)
) COMMENT='考勤排班表';

-- [表 2.1] 排班模板表
CREATE TABLE sys_schedule_templates (
    template_id INT AUTO_INCREMENT PRIMARY KEY,
    emp_id INT NOT NULL,
    day_of_week TINYINT NOT NULL,
    shift_type ENUM('休息', '早班', '晚班', '自定义') NOT NULL,
    plan_start TIME,
    plan_end TIME,
    is_deleted TINYINT(1) DEFAULT 0,
    FOREIGN KEY (emp_id) REFERENCES sys_employees(emp_id),
    UNIQUE KEY idx_emp_day (emp_id, day_of_week)
) COMMENT='周排班模板表';

-- [表 3] 系统通用图片附件表
CREATE TABLE sys_images (
    img_id INT AUTO_INCREMENT PRIMARY KEY,
    target_type ENUM('product', 'pet', 'employee', 'foster_record') NOT NULL,
    target_id INT NOT NULL,
    url VARCHAR(255) NOT NULL,
    is_primary TINYINT DEFAULT 0,
    sort_order INT DEFAULT 0,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    is_deleted TINYINT(1) DEFAULT 0,
    INDEX idx_target (target_type, target_id)
) COMMENT='全系统通用图片附件表';


-- ==========================================
-- 2. 会员与宠物
-- ==========================================

-- [表 4] 会员信息表
CREATE TABLE members (
    member_id INT AUTO_INCREMENT PRIMARY KEY,
    phone CHAR(11) UNIQUE NOT NULL COMMENT '手机号(唯一索引)',
    name VARCHAR(20) COMMENT '会员姓名',
    balance DECIMAL(8,2) UNSIGNED DEFAULT 0.00 COMMENT '储值余额',
    consume_amt DECIMAL(8,2) UNSIGNED DEFAULT 0.00 COMMENT '累计消费',
    points INT UNSIGNED DEFAULT 0 COMMENT '可用积分',
    level_name VARCHAR(10) DEFAULT '普通会员',
    pay_pwd VARCHAR(255) COMMENT '支付密码',
    
    -- 核心：乐观锁，防止并发扣款冲突
    version INT UNSIGNED DEFAULT 0 COMMENT '乐观锁版本号',
    
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    is_deleted TINYINT(1) DEFAULT 0,
    INDEX idx_name (name)
) COMMENT='会员档案';

-- [表 6] 宠物档案表 (对齐 PetInfo)
CREATE TABLE pets (
    pet_id INT AUTO_INCREMENT PRIMARY KEY,
    member_id INT NOT NULL,
    pet_name VARCHAR(20) NOT NULL,
    species VARCHAR(10) COMMENT '猫/狗/异宠',
    breed VARCHAR(20) COMMENT '具体品种',
    gender ENUM('公', '母', '绝育公', '绝育母', '未知') DEFAULT '未知',
    age_months INT UNSIGNED COMMENT '月龄',
    weight DECIMAL(5,2) UNSIGNED COMMENT '体重(kg)',
    health_status VARCHAR(50) COMMENT '健康状况',
    medical_history TEXT COMMENT '既往病史',
    vaccine_status TEXT COMMENT '疫苗记录',
    dietary_habit TEXT COMMENT '饮食习惯',
    avatar_path VARCHAR(255) COMMENT '头像路径',
    home_address VARCHAR(255) COMMENT '家庭接送地址',
    current_status ENUM('离店', '服务中', '寄养中') DEFAULT '离店',
    
    join_time DATETIME DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    is_deleted TINYINT(1) DEFAULT 0 COMMENT '逻辑删除(对应isActive)',
    
    FOREIGN KEY (member_id) REFERENCES members(member_id),
    INDEX idx_pet_name (pet_name)
) COMMENT='宠物核心档案';


-- ==========================================
-- 3. 商品与仓储管理 (升级版)
-- ==========================================

-- [表 7] 商品字典表 (对齐 ProductInfo)
CREATE TABLE products (
    product_id INT AUTO_INCREMENT PRIMARY KEY,
    barcode VARCHAR(50) UNIQUE NOT NULL,
    name VARCHAR(100) NOT NULL,
    brand VARCHAR(50) COMMENT '品牌',
    category VARCHAR(20) COMMENT '分类',
    origin VARCHAR(50) COMMENT '产地',
    spec VARCHAR(50) COMMENT '规格(如: 1.5kg/包)',
    unit VARCHAR(10) COMMENT '计件单位',
    purchase_price DECIMAL(7,2) UNSIGNED COMMENT '参考进价',
    sale_price DECIMAL(7,2) UNSIGNED NOT NULL COMMENT '零售价',
    
    -- 聚合库存 (依然保留，用于列表快速展示，具体出库看批次表)
    stock_current INT UNSIGNED DEFAULT 0,
    stock_min INT UNSIGNED DEFAULT 10,
    
    shelf_life_days INT UNSIGNED COMMENT '默认保质期(天)',
    supplier VARCHAR(100) COMMENT '默认供应商',
    supplier_phone VARCHAR(20),
    description TEXT COMMENT '商品描述',
    ingredients TEXT COMMENT '原料组成',
    nutrition_map JSON COMMENT '营养分析(支持灵活键值对)',
    storage_req VARCHAR(50) COMMENT '存储要求',
    tags VARCHAR(255) COMMENT '逗号分隔的卖点标签',
    net_weight_kg DECIMAL(5,2) COMMENT '净重(用于计算喂食量)',
    daily_feeding_grams INT COMMENT '建议日喂食量',
    
    is_active TINYINT(1) DEFAULT 1 COMMENT '是否上架',
    is_deleted TINYINT(1) DEFAULT 0,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP
) COMMENT='商品全局字典';

-- [新增表 7.1] 商品批次库存表 (对齐 StockBatch，解决先进先出问题)
CREATE TABLE product_batches (
    batch_id VARCHAR(32) PRIMARY KEY COMMENT '批次号(生成规则)',
    product_id INT NOT NULL,
    inbound_id INT NOT NULL COMMENT '关联入库单',
    production_date DATE COMMENT '生产日期',
    shelf_life_days INT UNSIGNED,
    expiry_date DATE COMMENT '过期日期(系统自动计算)',
    initial_qty INT UNSIGNED NOT NULL COMMENT '初始数量',
    current_qty INT UNSIGNED NOT NULL COMMENT '当前剩余数量',
    supplier VARCHAR(100),
    
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    is_deleted TINYINT(1) DEFAULT 0,
    FOREIGN KEY (product_id) REFERENCES products(product_id),
    INDEX idx_expiry (expiry_date, current_qty)
) COMMENT='库存批次表(FEFO管理核心)';


-- ==========================================
-- 4. 服务、预约与物流
