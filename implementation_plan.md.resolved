-- [表 8] 店内服务项目定义表 (对齐 ServiceInfo)
CREATE TABLE services (
    service_id INT AUTO_INCREMENT PRIMARY KEY,
    name VARCHAR(50) NOT NULL,
    category ENUM('洗护', '美容', '保健', '寄养', '接送') NOT NULL,
    price DECIMAL(10,2) NOT NULL,
    duration_min INT,
    commission_value DECIMAL(7,2) UNSIGNED,
    description TEXT,
    icon_path VARCHAR(255),
    status TINYINT DEFAULT 1,
    commission_amt DECIMAL(10,2),
    is_deleted TINYINT(1) DEFAULT 0
) COMMENT='店内服务项目字典';

-- [表 10] 预约单表 (对齐 AppointmentInfo)
CREATE TABLE appointments (
    appt_id INT AUTO_INCREMENT PRIMARY KEY,
    member_id INT NOT NULL,
    pet_id INT NOT NULL,
    service_id INT NOT NULL,
    staff_id INT,
    appt_time DATETIME NOT NULL,
    status ENUM('待处理', '进行中', '已完成', '已取消') DEFAULT '待处理',
    notes VARCHAR(255),
    FOREIGN KEY (member_id) REFERENCES members(member_id),
    FOREIGN KEY (pet_id) REFERENCES pets(pet_id),
    FOREIGN KEY (service_id) REFERENCES services(service_id),
    FOREIGN KEY (staff_id) REFERENCES sys_employees(emp_id)
) COMMENT='预约管理主表';

-- [新增表 10.2] 寄养房位表
CREATE TABLE foster_rooms (
    room_id INT AUTO_INCREMENT PRIMARY KEY,
    room_no VARCHAR(20) NOT NULL UNIQUE,
    room_type ENUM('普通', '豪华', '多宠') NOT NULL,
