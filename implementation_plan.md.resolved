-- 5. 寄养日志 (优化 JSON 痛点)
-- ==========================================

-- [新增表 11.1] 宠物日常活动跟踪表 (对齐 PetActivityLog)
CREATE TABLE pet_activity_logs (
    log_id BIGINT AUTO_INCREMENT PRIMARY KEY,
    foster_record_id INT COMMENT '关联寄养单(如果是寄养期间)',
    pet_id INT NOT NULL,
    log_time DATETIME NOT NULL COMMENT '发生时间',
    log_type VARCHAR(20) NOT NULL COMMENT '投喂/洗护/检查/异常',
    remark TEXT,
    icon_emoji VARCHAR(10) COMMENT '前端展示图标',
    is_alert TINYINT(1) DEFAULT 0 COMMENT '1:健康预警触发(标红)',
    operator_id INT NOT NULL COMMENT '经手人',
    room_no VARCHAR(20) COMMENT '发生时所在房位',
    
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    is_deleted TINYINT(1) DEFAULT 0,
    FOREIGN KEY (pet_id) REFERENCES pets(pet_id),
    INDEX idx_pet_time (pet_id, log_time)
) COMMENT='宠物健康/活动时间线表';

-- ==========================================
-- 6. 订单财务模块 (补充退单逻辑)
-- ==========================================

CREATE TABLE orders (
    order_id BIGINT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    order_no VARCHAR(32) UNIQUE NOT NULL,
    source_module VARCHAR(20) COMMENT '来源(Appointment/Boarding/Product)',
    related_id INT COMMENT '来源业务主键ID',
    member_id INT,
    pet_id INT,
    total_amount DECIMAL(8,2) UNSIGNED NOT NULL,
    discount DECIMAL(4,2) UNSIGNED DEFAULT 1.00 COMMENT '折扣率',
    actual_pay DECIMAL(8,2) UNSIGNED NOT NULL,
    payment_method VARCHAR(20) NOT NULL,
    status ENUM('待支付', '已支付', '已退款', '已作废') DEFAULT '已支付',
    cancel_reason VARCHAR(255) COMMENT '作废/退款原因',
    operator_id INT NOT NULL,
    
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    is_deleted TINYINT(1) DEFAULT 0,
    FOREIGN KEY (member_id) REFERENCES members(member_id),
    INDEX idx_order_no (order_no)
) COMMENT='财务对账单主表';


```

---

## 3. 核心方案与技术路径

### 3.1 事务一致性保障 (库存核减)
在进行收银结算时，使用 MySQL 事务确保库存与订单的一致性。特别注意，库存核减应优先从**最早到期的批次**（`product_batches`）中扣除（FEFO原则）：
```cpp
// 服务端逻辑伪代码
void processCheckout(OrderInfo order) {
    db.beginTransaction();
    try {
        // 1. 插入订单项
        // 2. 更新批次库存: 
        //    SELECT * FROM product_batches WHERE product_id = ? AND current_qty > 0 ORDER BY expiry_date ASC;
        //    逐个扣减 current_qty，直到满足订单数量。
        // 3. 更新商品表聚合库存: UPDATE products SET stock_current = stock_current - ? WHERE product_id = ?;
        // 4. 更新会员余额/积分 (使用乐观锁 version):
        //    UPDATE members SET balance = balance - ?, version = version + 1 WHERE member_id = ? AND version = ?;
        // 5. 检查库存预警并触发通知
        db.commit();
    } catch (...) {
        db.rollback();
    }
}
```

### 3.2 敏感数据安全
- **支付密码/员工密码**: 使用 `SHA-256` 加盐存储。
- **余额信息**: 采用 **数据签名**（HMAC）或服务端逻辑层校验流水之和，防止数据库被恶意篡改。

### 3.3 房态可视化 (Qt 实现)
- 使用 `QGraphicsScene` 绘制。
- 每个房间为一个 `QGraphicsItem`，绑定 `room_id`。
- 通过计时器或服务端 **Push 机制** 实时更新 UI 状态。

### 3.4 通用图片库组件 (Qt 实现)
为支持商品、宠物、寄养记录的多图展示，设计一个通用的 `ImageGallery` 控件：
- **布局**: 基于 `QScrollArea` + 自定义 `FlowLayout`（流式布局）展示预览缩略图。
- **功能**:
  - 点击缩略图可弹出 `QDialog` 查看高清原图。
  - 右键菜单支持“设为主图”、“删除照片”、“下载到本地”。
  - 接入开源的图像处理库或简单的 `QImage` 缩放实现预览加速。
- **数据交互**:
  - 启动时根据 `target_type` 和 `target_id` 异步从服务端下载图片（先下载缩略图列表，再按需下载大图）。
  - 支持拖拽上传图片至该控件。

### 3.5 基于角色的访问控制 (RBAC) 设计
系统根据登录身份自动切换 UI 视图和操作权限：
- **店长 (Manager)**: 拥有全局权限，包括财务报表、员工提成设置、订单撤回、系统参数配置。
- **收银 (Cashier)**: 核心业务操作，包括收银、会员充值、寄养/预约登记。不可查看敏感财务报表。
- **美容师 (Staff/Groomer)**: 专注服务执行。仅可查看指派给自己的预约，记录服务进度（如：洗澡中、已完成）及上传寄养日志。仅能看到自己的提成统计。

## 4. 验证计划

### 自动化测试
- 编写 Python 脚本模拟 100 个客户端并发执行“库存扣减”压力测试。
- 使用 `gtest` 进行服务端协议解析单元测试。

### 模拟验证
- 模拟“扫码入库 -> 修改库存阈值 -> 触发自动通知”的闭环测试。
- 模拟“同一时间点预约同一工位”的冲突检测逻辑。
