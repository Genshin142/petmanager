    has_camera TINYINT(1) DEFAULT 0
) COMMENT='寄养房位表';

-- [新增表 10.3] 寄养房位表(新版)
CREATE TABLE boarding_rooms (
    room_id INT AUTO_INCREMENT PRIMARY KEY,
    room_no VARCHAR(20) NOT NULL UNIQUE,
    room_type ENUM('标准房', '豪华房', '多宠房') NOT NULL,
    status ENUM('空闲', '已预订', '入住中', '清理中', '维护中') DEFAULT '空闲',
    current_pet_id INT,
    description TEXT
) COMMENT='寄养房位表( boarding_rooms )';

-- [新增表 10.4] 寄养记录表
CREATE TABLE boarding_records (
    record_id INT AUTO_INCREMENT PRIMARY KEY,
    room_no VARCHAR(20) NOT NULL,
    pet_id INT NOT NULL,
    member_id INT NOT NULL,
    check_in_time DATETIME NOT NULL,
