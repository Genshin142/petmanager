# 宠物店信息管理系统（Pet Management System）实现计划

本方案旨在设计一个基于 Qt (Client) 和 Linux C++ (Server) 的高性能宠物店管理系统。系统将通过 MySQL 进行持久化存储，并采用 TCP 协议进行高效的数据交互。

## 1. 核心架构设计

### 1.1 系统拓扑 (C/S 架构)
- **客户端 (Qt 6.x)**: 
  - 采用 **Model/View** 架构解耦 UI 与数据。
  - **网络层**: 基于 `QTcpSocket` 封装异步请求管理器，支持二进制流/JSON 数据交换。
  - **UI 特色**: 房态图组件（自定义 QGraphicsView）、收银扫码支持。
- **服务端 (Linux / C++)**:
  - **核心协议**: 自定义 TCP 协议（4字节消息长度头 + 消息体）。
  - **并发处理**: 采用 **Reactor 模式** (Epoll + 线程池) 处理海量连接。
  - **数据层**: 使用 **MySQL 连接池** 提升 SQL 执行效率，减少频繁握手开销。

---

## 2. 数据库逻辑建模 (MySQL)


-- ==========================================
-- 1. 员工与系统配置
-- ==========================================

-- [表 1] 员工信息表 (对齐 EmployeeInfo)
CREATE TABLE sys_employees (
    emp_id INT AUTO_INCREMENT PRIMARY KEY,
    username VARCHAR(32) NOT NULL UNIQUE COMMENT '登录账号',
    password VARCHAR(255) NOT NULL COMMENT '密码哈希',
    real_name VARCHAR(20) NOT NULL COMMENT '真实姓名',
    role ENUM('店长', '收银', '美容师', '司机') NOT NULL COMMENT '角色',
    department VARCHAR(50) COMMENT '所属部门',
    gender ENUM('男', '女', '未知') DEFAULT '未知',
    age TINYINT UNSIGNED COMMENT '年龄',
    phone CHAR(11) UNIQUE COMMENT '手机号',
    email VARCHAR(50) COMMENT '邮箱',
    id_card CHAR(18) COMMENT '身份证号',
    base_salary DECIMAL(10,2) COMMENT '基础底薪',
    join_date DATE COMMENT '入职日期',
    emergency_contact VARCHAR(20) COMMENT '紧急联系人',
    emergency_phone CHAR(11) COMMENT '紧急联系电话',
    address VARCHAR(255) COMMENT '住址',
    education VARCHAR(20) COMMENT '学历',
    status ENUM('在职', '请假', '离职') DEFAULT '在职',
    img_url VARCHAR(255) COMMENT '头像路径',
    
    -- 审计字段
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    is_deleted TINYINT(1) DEFAULT 0 COMMENT '0:有效 1:逻辑删除',
    INDEX idx_real_name (real_name),
    INDEX idx_phone (phone)
) COMMENT='员工全维度档案表';

-- [新增表 1.1] 系统操作日志表 (对齐 SysOperationLog)
CREATE TABLE sys_operation_logs (
    log_id BIGINT AUTO_INCREMENT PRIMARY KEY,
    operator_name VARCHAR(20) NOT NULL COMMENT '操作人姓名',
    module VARCHAR(50) NOT NULL COMMENT '操作模块',
    action VARCHAR(50) NOT NULL COMMENT '动作',
    details TEXT COMMENT '详情',
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    INDEX idx_time_module (created_at)
) COMMENT='系统操作审计日志';

-- [新增表 1.2] 员工薪资发放记录 (对齐 SalaryInfo)
CREATE TABLE salary_records (
    salary_id INT AUTO_INCREMENT PRIMARY KEY,
    emp_id INT NOT NULL,
    salary_month CHAR(7) NOT NULL COMMENT '薪资月份 YYYY-MM',
    base_salary DECIMAL(10,2) DEFAULT 0.00,
    commission DECIMAL(10,2) DEFAULT 0.00,
    bonus DECIMAL(10,2) DEFAULT 0.00,
    deduction DECIMAL(10,2) DEFAULT 0.00,
    net_pay DECIMAL(10,2) DEFAULT 0.00,
    status ENUM('待审核', '已发放') DEFAULT '待审核',
    pay_time DATETIME,
    remark VARCHAR(255),
    FOREIGN KEY (emp_id) REFERENCES sys_employees(emp_id)
) COMMENT='月度薪资核算表';

-- [表 2] 排班与考勤表
CREATE TABLE sys_schedules (
    schedule_id INT AUTO_INCREMENT PRIMARY KEY,
    emp_id INT NOT NULL,
    work_date DATE NOT NULL,
    shift_type ENUM('休息', '早班', '晚班', '自定义') NOT NULL,
    plan_start TIME,
    plan_end TIME,
    clock_in DATETIME,
    clock_out DATETIME,
    note VARCHAR(100),
    is_deleted TINYINT(1) DEFAULT 0,
    FOREIGN KEY (emp_id) REFERENCES sys_employees(emp_id)
) COMMENT='考勤排班表';

-- [表 2.1] 排班模板表
CREATE TABLE sys_schedule_templates (
    template_id INT AUTO_INCREMENT PRIMARY KEY,
    emp_id INT NOT NULL,
    day_of_week TINYINT NOT NULL,
    shift_type ENUM('休息', '早班', '晚班', '自定义') NOT NULL,
    plan_start TIME,
    plan_end TIME,
    FOREIGN KEY (emp_id) REFERENCES sys_employees(emp_id)
) COMMENT='周排班模板表';

-- [表 3] 系统通用图片附件表
CREATE TABLE sys_images (
    img_id INT AUTO_INCREMENT PRIMARY KEY,
    target_type ENUM('product', 'pet', 'employee', 'foster_record') NOT NULL,
    target_id INT NOT NULL,
    url VARCHAR(255) NOT NULL,
    is_primary TINYINT DEFAULT 0,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    INDEX idx_target (target_type, target_id)
) COMMENT='全系统通用图片附件表';


-- ==========================================
-- 2. 会员与宠物
-- ==========================================

-- [表 4] 会员信息表
CREATE TABLE members (
    member_id INT AUTO_INCREMENT PRIMARY KEY,
    phone CHAR(11) UNIQUE NOT NULL COMMENT '手机号',
    name VARCHAR(20) COMMENT '姓名',
    gender ENUM('男', '女', '未知') DEFAULT '未知',
    birthday DATE,
    balance DECIMAL(12,2) DEFAULT 0.00,
    consume_amt DECIMAL(12,2) DEFAULT 0.00,
    points INT UNSIGNED DEFAULT 0,
    level_name VARCHAR(10) DEFAULT '普通会员',
    pay_pwd VARCHAR(100),
    version INT UNSIGNED DEFAULT 0 COMMENT '乐观锁版本号',
    is_deleted TINYINT(1) DEFAULT 0,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    INDEX idx_name (name)
) COMMENT='会员档案';

-- [表 6] 宠物档案表 (对齐 PetInfo)
CREATE TABLE pets (
    pet_id INT AUTO_INCREMENT PRIMARY KEY,
    member_id INT NOT NULL,
    pet_name VARCHAR(20) NOT NULL,
    species VARCHAR(10) COMMENT '物种',
    breed VARCHAR(20) COMMENT '品种',
    gender ENUM('公', '母', '绝育公', '绝育母', '未知') DEFAULT '未知',
    age_months INT UNSIGNED,
    weight DECIMAL(6,2),
    health_status VARCHAR(50),
    medical_history TEXT,
    vaccine_status TEXT,
    dietary_habit TEXT,
    avatar_path VARCHAR(255),
    home_address VARCHAR(255),
    current_status VARCHAR(50),
    join_time DATETIME DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    is_deleted TINYINT(1) DEFAULT 0,
    FOREIGN KEY (member_id) REFERENCES members(member_id),
    INDEX idx_pet_name (pet_name)
) COMMENT='宠物核心档案';


