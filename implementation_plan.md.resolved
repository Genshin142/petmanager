CREATE TABLE sys_performance_records (
    perf_id BIGINT AUTO_INCREMENT PRIMARY KEY,
    emp_id INT NOT NULL,
    order_id VARCHAR(32) NOT NULL,
    service_date DATE NOT NULL,
    service_name VARCHAR(50),
    order_amount DECIMAL(10,2) NOT NULL,
    commission_amt DECIMAL(10,2) NOT NULL,
    status ENUM('待核销', '已核销') DEFAULT '待核销',
    verify_time DATETIME,
    FOREIGN KEY (emp_id) REFERENCES sys_employees(emp_id)
) COMMENT='员工绩效记录表';


